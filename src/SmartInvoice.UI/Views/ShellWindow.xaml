<ui:FluentWindow x:Class="SmartInvoice.UI.Views.ShellWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Smart Invoice"
                 Height="800" Width="1280"
                 MinHeight="600" MinWidth="1000"
                 WindowState="Maximized"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <ui:TitleBar ShowMaximize="True" ShowMinimize="True" />
        <!-- Tiêu đề đè bên trái (TitleBar template có thể đặt Header giữa/phải, nên dùng overlay) -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,6,0,0"
                    IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Icon app ở title bar: dùng chính SmartInvoice.ico -->
                <Image Source="pack://application:,,,/SmartInvoice.UI;component/SmartInvoice.ico"
                       Width="16" Height="16" Margin="0,0,8,0" />
                <TextBlock Text="Smart Invoice" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource SiTextPrimary}" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
        <ContentControl x:Name="MainContent" Margin="0,32,0,0" />
    </Grid>
</ui:FluentWindow>

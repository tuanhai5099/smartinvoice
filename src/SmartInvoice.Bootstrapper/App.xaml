<Application x:Class="SmartInvoice.Bootstrapper.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:conv="clr-namespace:SmartInvoice.Modules.Companies.Converters;assembly=SmartInvoice.Modules.Companies">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- DatePicker/Calendar: tạm dùng style mặc định của WPF/WpfUI để đảm bảo ổn định, tránh crash do template nội bộ -->

            <!-- Custom strong colors for Light theme readability -->
            <SolidColorBrush x:Key="SiTextPrimary" Color="#1A1A2E" />
            <SolidColorBrush x:Key="SiTextSecondary" Color="#555770" />
            <SolidColorBrush x:Key="SiTextMuted" Color="#8B8DA3" />
            <SolidColorBrush x:Key="SiAccent" Color="#0066CC" />
            <SolidColorBrush x:Key="SiAccentLight" Color="#E8F0FE" />
            <SolidColorBrush x:Key="SiCardBg" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SiCardBorder" Color="#E2E4EA" />
            <SolidColorBrush x:Key="SiPageBg" Color="#F4F5F7" />
            <SolidColorBrush x:Key="SiDanger" Color="#D32F2F" />
            <SolidColorBrush x:Key="SiTextOnDanger" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SiHeaderBg" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SiHeaderBorder" Color="#E0E0E0" />
            <SolidColorBrush x:Key="SiRowHover" Color="#F0F2F8" />
            <SolidColorBrush x:Key="SiDivider" Color="#EAEDF0" />

            <!-- Màu nút rõ ràng + hover đẹp, bo góc 6px. Template dùng TemplateBinding Background để hover đổi màu đúng. -->
            <SolidColorBrush x:Key="SiSecondaryBg" Color="#E2E4EA" />
            <SolidColorBrush x:Key="SiSecondaryFg" Color="#1A1A2E" />
            <!-- Hover: đậm hơn rõ ràng, đẹp -->
            <SolidColorBrush x:Key="SiAccentHover" Color="#004C99" />
            <SolidColorBrush x:Key="SiSecondaryHover" Color="#B8BCC8" />
            <SolidColorBrush x:Key="SiDangerHover" Color="#A01515" />

            <!-- Template nút: bo góc 6, nền bind Background để hover đổi màu đúng; giữ Icon + Content -->
            <ControlTemplate x:Key="SiButtonTemplate" TargetType="ui:Button">
                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6" Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ContentPresenter x:Name="IconPresenter" Content="{TemplateBinding Icon}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"
                                          VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Cursor" Value="Hand" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.5" TargetName="Bd" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="Template" Value="{StaticResource SiButtonTemplate}" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="BorderThickness" Value="0" />
                <Style.Triggers>
                    <!-- Primary -->
                    <Trigger Property="Appearance" Value="Primary">
                        <Setter Property="Background" Value="{StaticResource SiAccent}" />
                        <Setter Property="Foreground" Value="White" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Appearance" Value="Primary" />
                            <Condition Property="IsMouseOver" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource SiAccentHover}" />
                    </MultiTrigger>
                    <!-- Secondary -->
                    <Trigger Property="Appearance" Value="Secondary">
                        <Setter Property="Background" Value="{StaticResource SiSecondaryBg}" />
                        <Setter Property="Foreground" Value="{StaticResource SiSecondaryFg}" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Appearance" Value="Secondary" />
                            <Condition Property="IsMouseOver" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource SiSecondaryHover}" />
                    </MultiTrigger>
                    <!-- Danger -->
                    <Trigger Property="Appearance" Value="Danger">
                        <Setter Property="Background" Value="{StaticResource SiDanger}" />
                        <Setter Property="Foreground" Value="{StaticResource SiTextOnDanger}" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Appearance" Value="Danger" />
                            <Condition Property="IsMouseOver" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource SiDangerHover}" />
                    </MultiTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

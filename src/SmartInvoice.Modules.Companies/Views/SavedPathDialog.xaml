<Window x:Class="SmartInvoice.Modules.Companies.Views.SavedPathDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đã lưu file" Width="480" Height="180" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="File đã được lưu tại:" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBox x:Name="PathBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Mở thư mục chứa file" Width="160" Padding="12,6" Margin="0,0,8,0"
                    Click="OpenFolder_Click" />
            <Button Content="Đóng" Width="80" Padding="12,6" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

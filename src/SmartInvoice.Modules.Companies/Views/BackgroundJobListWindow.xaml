<ui:FluentWindow x:Class="SmartInvoice.Modules.Companies.Views.BackgroundJobListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:SmartInvoice.Modules.Companies.Converters"
        xmlns:domain="clr-namespace:SmartInvoice.Core.Domain;assembly=SmartInvoice.Core"
        Language="vi-VN"
        Title="Quản lý chạy tự động"
        Width="1100" Height="680"         MinWidth="800" MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <Window.Resources>
        <converters:JobStatusToTextConverter x:Key="JobStatusToText" />
        <DataTemplate x:Key="JobStatusTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:ProgressRing x:Name="StatusRing" Width="18" Height="18" IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" Margin="6,0,0,0" VerticalAlignment="Center" Text="{Binding Status, Converter={StaticResource JobStatusToText}}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:BackgroundJobStatus.Running}">
                    <Setter TargetName="StatusRing" Property="Visibility" Value="Visible" />
                    <Setter TargetName="StatusText" Property="Text" Value="Đang chạy" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static domain:BackgroundJobStatus.Pending}">
                    <Setter TargetName="StatusRing" Property="Visibility" Value="Visible" />
                    <Setter TargetName="StatusText" Property="Text" Value="Đang chờ" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <ui:TitleBar Title="Quản lý chạy tự động" ShowMaximize="True" ShowMinimize="False" />

        <Grid Margin="20,48,20,20">
            <!-- Hàng 1–2: tỉ lệ cố định (2:1) theo cửa sổ — không co giãn theo nội dung job/chi tiết (tránh giật layout) -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" MinHeight="180" />
                <RowDefinition Height="*" MinHeight="160" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Các job tải nền (đang chạy và gần đây, mới nhất trước)"
                       FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SiTextPrimary}" Margin="0,0,0,12" />

            <Grid Grid.Row="1" MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="0" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            <DataGrid Grid.Row="0" x:Name="JobsGrid"
                      ItemsSource="{Binding Jobs}"
                      SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Margin="0,0,0,8"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Công ty" Binding="{Binding CompanyName}" Width="*" MinWidth="100" />
                    <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*" MinWidth="120" />
                    <DataGridTemplateColumn Header="Trạng thái" Width="120" CellTemplate="{StaticResource JobStatusTemplate}" />
                    <DataGridTextColumn Header="Tiến trình" Width="180" MinWidth="120"
                        Binding="{Binding ProgressDisplayText}" />
                    <DataGridTextColumn Header="Tạo lúc" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="110" />
                    <DataGridTextColumn Header="Lỗi" Binding="{Binding LastError}" Width="*" MinWidth="80" />
                </DataGrid.Columns>
            </DataGrid>
                <Border Grid.Row="1" Padding="8,6" Margin="0,4,0,0"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="Trang " VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text=" / " VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" />
                        <TextBlock Text="  (tổng " VerticalAlignment="Center" Margin="8,0,0,0" />
                        <TextBlock Text="{Binding TotalCount}" VerticalAlignment="Center" />
                        <TextBlock Text=" job)" VerticalAlignment="Center" />
                        <ui:Button Content="Trước" Command="{Binding PrevPageCommand}" Appearance="Secondary"
                                   Padding="10,4" FontSize="12" Margin="12,0,0,0" />
                        <ui:Button Content="Sau" Command="{Binding NextPageCommand}" Appearance="Secondary"
                                   Padding="10,4" FontSize="12" Margin="4,0,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Chiếm một phần chiều cao cố định theo tỉ lệ Grid; nội dung dài chỉ cuộn bên trong -->
            <Border Grid.Row="2" Padding="12" Margin="0,0,0,12" MinHeight="0"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalAlignment="Stretch"
                              Padding="0">
                    <StackPanel>
                        <TextBlock Text="Báo cáo chi tiết job đang chọn" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mô tả: " FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedJob.Description, FallbackValue='—'}"
                                       TextWrapping="Wrap" VerticalAlignment="Top" />
                        </Grid>
                        <TextBlock Text="{Binding SelectedJob.ReportSummary, FallbackValue='—'}"
                                   TextWrapping="Wrap" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="File kết quả (ZIP/XML/Excel): " FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="{Binding SelectedJob.ResultPath, FallbackValue='—'}"
                                       TextWrapping="Wrap" VerticalAlignment="Top"
                                       ToolTip="{Binding SelectedJob.ResultPath}" />
                        </Grid>
                        <WrapPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold" Text="Tạo lúc: " VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedJob.CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}', FallbackValue='—'}" VerticalAlignment="Center" Margin="0,0,16,4" />
                            <TextBlock FontWeight="SemiBold" Text="Bắt đầu: " VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedJob.StartedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}', TargetNullValue='—', FallbackValue='—'}" VerticalAlignment="Center" Margin="0,0,16,4" />
                            <TextBlock FontWeight="SemiBold" Text="Kết thúc: " VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedJob.FinishedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}', TargetNullValue='—', FallbackValue='—'}" VerticalAlignment="Center" Margin="0,0,0,4" />
                        </WrapPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lỗi: " FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,0,8,0" />
                            <Border Grid.Column="1"
                                    Background="#10FF0000"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6"
                                    MinHeight="48">
                                <TextBlock Text="{Binding SelectedJob.LastError, TargetNullValue='-', FallbackValue='-'}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           Foreground="{DynamicResource SiTextSecondary}" Margin="0,0,16,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Mở thư mục" Command="{Binding OpenFolderCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                    <ui:Button Content="Làm mới" Command="{Binding RefreshCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                    <ui:Button Content="Lại chi tiết lỗi" Command="{Binding RetryFailedDetailCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0"
                               ToolTip="Tạo job mới chỉ gọi API chi tiết cho hóa đơn thất bại / thiếu dữ liệu" />
                    <ui:Button Content="Lại XML lỗi" Command="{Binding RetryFailedXmlCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0"
                               ToolTip="Tạo job tải lại XML cho hóa đơn lỗi (không tính trường hợp không có XML)" />
                    <ui:Button Content="Lại PDF lỗi" Command="{Binding RetryFailedPdfCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0"
                               ToolTip="Tạo job tải lại PDF cho hóa đơn lỗi (job PDF hàng loạt)" />
                    <ui:Button Content="Thử lại (job lỗi)" Command="{Binding RetryCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                    <ui:Button Content="Hủy (job chờ)" Command="{Binding CancelCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                    <ui:Button Content="Xóa" Command="{Binding DeleteCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" Margin="0,0,6,0" />
                    <ui:Button Content="Xóa tất cả" Command="{Binding DeleteAllCommand}"
                               Appearance="Secondary" Padding="12,6" FontSize="12" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
